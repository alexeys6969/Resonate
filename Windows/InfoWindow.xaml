<Window x:Class="Resonate.Windows.InfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Информация" Height="260" Width="480" 
        Background="#1a1a1a" ResizeMode="NoResize" 
        WindowStyle="None" WindowStartupLocation="CenterScreen"
        AllowsTransparency="True">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="0"/>
    </WindowChrome.WindowChrome>

    <Border Background="#252525" CornerRadius="20" BorderBrush="#3a3a3a" BorderThickness="1"
            Effect="{StaticResource CardShadow}">
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Логотип + иконка -->
            <StackPanel HorizontalAlignment="Center" Margin="0,0,0,15">
                <TextBlock Text="ℹ️" FontSize="32" HorizontalAlignment="Center"/>
                <TextBlock Text="Resonate" 
                           FontFamily="\Fonts\Inter-VariableFont_opsz,wght.ttf"
                           FontSize="24" FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0">
                    <TextBlock.Foreground>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#8EED45" Offset="0"/>
                            <GradientStop Color="#24E3ED" Offset="1"/>
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                </TextBlock>
            </StackPanel>

            <!-- Сообщение -->
            <TextBlock x:Name="windowInfo" 
                       Grid.Row="1"
                       FontFamily="\Fonts\Inter-VariableFont_opsz,wght.ttf"
                       FontSize="15" FontWeight="Light"
                       Foreground="#ffffff"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       VerticalAlignment="Center"
                       Margin="0,10,0,25"/>

            <!-- Кнопка ОК -->
            <Button Grid.Row="2"
                    Click="OkClick"
                    Content="✅ Понятно"
                    Style="{StaticResource DialogButton}"
                    Width="180" Height="45"
                    HorizontalAlignment="Center"/>
        </Grid>
    </Border>
</Window>