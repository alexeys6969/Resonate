<Window x:Class="Resonate.Windows.DialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Подтверждение" Height="280" Width="480" 
        Background="#1a1a1a" ResizeMode="NoResize" 
        WindowStyle="None" WindowStartupLocation="CenterScreen"
        AllowsTransparency="True">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="0"/>
    </WindowChrome.WindowChrome>

    <Border Background="#252525" CornerRadius="20" BorderBrush="#3a3a3a" BorderThickness="1"
            Effect="{StaticResource CardShadow}">
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Логотип -->
            <TextBlock Text="Resonate" 
                       FontFamily="\Fonts\Inter-VariableFont_opsz,wght.ttf"
                       FontSize="24" FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20">
                <TextBlock.Foreground>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#8EED45" Offset="0"/>
                        <GradientStop Color="#24E3ED" Offset="1"/>
                    </LinearGradientBrush>
                </TextBlock.Foreground>
            </TextBlock>

            <!-- Вопрос -->
            <TextBlock x:Name="questionText" 
                       Grid.Row="1"
                       FontFamily="\Fonts\Inter-VariableFont_opsz,wght.ttf"
                       FontSize="16" FontWeight="Light"
                       Foreground="#ffffff"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       VerticalAlignment="Center"
                       Margin="0,10,0,30"/>

            <!-- Кнопки -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="YesButton"
                        Click="Yes"
                        Content="✅ Да"
                        Style="{StaticResource DialogButton}"
                        Width="140" Height="45"
                        Margin="0,0,15,0"
                        Tag="confirm"/>

                <Button x:Name="NoButton"
                        Click="No"
                        Content="❌ Нет"
                        Style="{StaticResource DialogButtonSecondary}"
                        Width="140" Height="45"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>