<Window x:Class="Resonate.Windows.DialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Resonate.Windows"
        mc:Ignorable="d"
        Title="DialogWindow" Height="260" Width="520" Background="#292929">
    <StackPanel HorizontalAlignment="Center" Width="345">
        <TextBlock Style="{StaticResource LogoTb}"/>
        <TextBlock Style="{StaticResource MainTb}" TextWrapping="Wrap" Text="Выберите таблицу, для которой надо сформировать отчет" Margin="0" />
        <Grid VerticalAlignment="Bottom" Margin="0,20,0,20">
            <Button Style="{StaticResource MainButton}" Content="Да" HorizontalAlignment="Left" Height="35" Width="150"/>
            <Button Style="{StaticResource MainButton}" Content="Нет" HorizontalAlignment="Right" Height="35" Width="150"/>
        </Grid>
    </StackPanel>
</Window>
