<UserControl x:Class="Resonate.Elements.TableItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Resonate.Elements"
             mc:Ignorable="d" 
             HorizontalAlignment="Stretch" 
             VerticalAlignment="Stretch"
             Margin="0,0,10,0">
    <Button Style="{StaticResource AuthButton}" Margin="0,10,0,0" 
            
            HorizontalAlignment="Stretch" 
            VerticalAlignment="Stretch"
            HorizontalContentAlignment="Center"
            VerticalContentAlignment="Center"
            MinHeight="100"
            Background="#FFFFFF" >

        <Border CornerRadius="15" 
                Background="#FFFFFF"
                HorizontalAlignment="Stretch" 
                VerticalAlignment="Stretch"
>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Image Source="/Images/category.png" 
                       Width="60" Height="60"
                    Stretch="Uniform"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,0"/>
                    <TextBlock Style="{StaticResource MainTb}" 
                           Text="Категории" 
                           Foreground="#000000" 
                           Margin="0,0,0,5"  
                           FontSize="20"
                           FontWeight="Light"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           TextAlignment="Center"/>
            </StackPanel>
        </Border>
    </Button>
</UserControl>