<Application x:Class="Resonate.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Resonate"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <Style x:Key="LogoTb" TargetType="TextBlock">
            <Setter Property="Text" Value="Resonate"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,20,0,0"/>
            <Setter Property="Margin" Value="0,20,0,0"/>
            <Setter Property="Margin" Value="0,20,0,0"/>
            <Setter Property="Margin" Value="0,20,0,0"/>
            <Setter Property="FontFamily" Value="\Fonts\Inter-VariableFont_opsz,wght.ttf"/>
            <Setter Property="FontSize" Value="32"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#FCC7C7" Offset="0.0"/>
                        <GradientStop Color="#967777" Offset="1.0"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MainTb" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="\Fonts\Inter-VariableFont_opsz,wght.ttf"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="ExtraLight"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Margin" Value="0,20,0,0"/>
        </Style>

        <Style x:Key="MainTextbox" TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
            <Setter Property="BorderBrush" Value="#FFFFFF"/>
            <Setter Property="FontFamily" Value="\Fonts\Inter-VariableFont_opsz,wght.ttf"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="ExtraLight"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Name="border" 
                            Background="Transparent"
                            BorderBrush="#FFFFFF"
                            BorderThickness="1"
                            CornerRadius="15">
                            <ScrollViewer x:Name="PART_ContentHost" 
                                  VerticalAlignment="Center"
                                  Margin="5,0"
                                  Background="Transparent"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MainPasswordbox" TargetType="PasswordBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
            <Setter Property="BorderBrush" Value="#FFFFFF"/>
            <Setter Property="FontFamily" Value="\Fonts\Inter-VariableFont_opsz,wght.ttf"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="ExtraLight"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Name="border" 
                            Background="Transparent"
                            BorderBrush="#FFFFFF"
                            BorderThickness="1"
                            CornerRadius="15">
                            <ScrollViewer x:Name="PART_ContentHost" 
                                  VerticalAlignment="Center"
                                  Margin="5,0"
                                  Background="Transparent"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AuthButton" TargetType="Button">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#FCC7C7" Offset="0.0"/>
                        <GradientStop Color="#967777" Offset="1.0"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>

            <Setter Property="Margin" Value="0,40,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Name="border" 
                        Background="{TemplateBinding Background}"
                        BorderThickness="1"
                        CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                    Content="{TemplateBinding Content}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Content" Value="Авторизоваться"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="FontFamily" Value="/Fonts/Inter-VariableFont_opsz,wght.ttf#Inter"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="ExtraLight"/>
            <Setter Property="Foreground" Value="#000000"/>
        </Style>
    </Application.Resources>
</Application>
