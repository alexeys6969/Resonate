<Page x:Class="Resonate.Pages.Authorization"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:Resonate.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="900"
      Title="Authorization" Background="#1a1a1a">

    <Page.Resources>
        <!-- Анимация появления -->
        <Storyboard x:Key="FadeIn">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" 
                           From="0" To="1" Duration="0:0:0.4"/>
            <ThicknessAnimation Storyboard.TargetProperty="Margin" 
                              From="0,20,0,0" To="0,0,0,0" Duration="0:0:0.4"/>
        </Storyboard>
    </Page.Resources>

    <Grid>
        <!-- Фоновый градиент -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#1a1a1a" Offset="0"/>
                <GradientStop Color="#252525" Offset="0.5"/>
                <GradientStop Color="#1f1f1f" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Декоративные элементы фона -->
        <Ellipse Width="400" Height="400" Fill="#FCC7C7" Opacity="0.03" 
                 HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-100,-100,0,0"/>
        <Ellipse Width="300" Height="300" Fill="#967777" Opacity="0.05" 
                 HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-50,-50"/>

        <!-- Карточка авторизации -->
        <Border x:Name="AuthCard"
                Width="420" Height="520" 
                Background="#2a2a2a" 
                CornerRadius="24" 
                BorderBrush="#3a3a3a"
                BorderThickness="1"
                HorizontalAlignment="Center" 
                VerticalAlignment="Center"
                Effect="{StaticResource CardShadow}">

            <Grid Margin="40,35">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Логотип и заголовок -->
                <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,25">
                    <TextBlock Text="Resonate" 
                               FontFamily="\Fonts\Inter-VariableFont_opsz,wght.ttf"
                               FontSize="36" FontWeight="Bold"
                               HorizontalAlignment="Center">
                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#8EED45" Offset="0"/>
                                <GradientStop Color="#24E3ED" Offset="1"/>
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                    </TextBlock>
                    <TextBlock Text="Вход в систему" 
                               FontFamily="\Fonts\Inter-VariableFont_opsz,wght.ttf"
                               FontSize="16" FontWeight="Light"
                               Foreground="#888888"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0"/>
                </StackPanel>

                <!-- Поля ввода -->
                <StackPanel Grid.Row="1" VerticalAlignment="Center">

                    <!-- Логин -->
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="Логин" 
                                   FontFamily="\Fonts\Inter-VariableFont_opsz,wght.ttf"
                                   FontSize="13" FontWeight="Medium"
                                   Foreground="#cccccc"
                                   Margin="0,0,0,8"/>
                        <Border x:Name="LoginBorder"
                                Background="#333333" 
                                BorderBrush="#444444"
                                BorderThickness="1.5"
                                CornerRadius="12"
                                Padding="14,10">
                            <TextBox x:Name="EmployeeLogin"
                                     Style="{StaticResource TransparentTextBox}"
                                     Tag="Введите логин"/>
                        </Border>
                    </StackPanel>

                    <!-- Пароль -->
                    <StackPanel Margin="0,0,0,25">
                        <TextBlock Text="Пароль" 
                                   FontFamily="\Fonts\Inter-VariableFont_opsz,wght.ttf"
                                   FontSize="13" FontWeight="Medium"
                                   Foreground="#cccccc"
                                   Margin="0,0,0,8"/>
                        <Border x:Name="PasswordBorder"
                                Background="#333333" 
                                BorderBrush="#444444"
                                BorderThickness="1.5"
                                CornerRadius="12"
                                Padding="14,10">
                            <PasswordBox x:Name="EmployeePassword"
                                         Style="{StaticResource TransparentPasswordBox}"
                                         Tag="Введите пароль"/>
                        </Border>
                    </StackPanel>

                    <!-- Кнопка входа -->
                    <Button x:Name="AuthButton" 
                            Click="AuthBtn"
                            IsDefault="True"
                            Style="{StaticResource ModernButton}"
                            Content="Войти"
                            Margin="0,10,0,0"/>

                    <!-- Ссылка "Забыли пароль?" -->
                    <TextBlock Text="Забыли пароль?" 
                               FontFamily="\Fonts\Inter-VariableFont_opsz,wght.ttf"
                               FontSize="13"
                               Foreground="#6699cc"
                               HorizontalAlignment="Center"
                               Margin="0,20,0,0"
                               Cursor="Hand"
                               MouseLeftButtonDown="ForgotPassword_Click"/>
                </StackPanel>

                <!-- Футер -->
                <TextBlock Grid.Row="2" 
                           Text="© 2026 Resonate. Все права защищены."
                           FontFamily="\Fonts\Inter-VariableFont_opsz,wght.ttf"
                           FontSize="11"
                           Foreground="#555555"
                           HorizontalAlignment="Center"
                           Margin="0,25,0,0"/>
            </Grid>
        </Border>
    </Grid>
</Page>