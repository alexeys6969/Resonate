<Page x:Class="Resonate.Pages.Authorization"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Resonate.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Authorization" Background="#292929">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="25*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <StackPanel VerticalAlignment="Top" Grid.ColumnSpan="3">
            <TextBlock Style="{StaticResource LogoTb}"/>
            <TextBlock Text="Авторизация" Style="{StaticResource MainTb}" HorizontalAlignment="Center" Margin="0,10,0,0"/>
        </StackPanel>
        <StackPanel Margin="0,92,0,0" Grid.Column="1">
            <TextBlock Text="Введите логин" Style="{StaticResource MainTb}" HorizontalAlignment="Left"/>
            <TextBox Style="{StaticResource MainTextbox}"/>
            <TextBlock Text="Введите Email" Style="{StaticResource MainTb}" HorizontalAlignment="Left"/>
            <TextBox Style="{StaticResource MainTextbox}"/>
            <TextBlock Text="Введите пароль" Style="{StaticResource MainTb}" HorizontalAlignment="Left"/>
            <PasswordBox Style="{StaticResource MainPasswordbox}"/>
        </StackPanel>
        <StackPanel Grid.Column="1" VerticalAlignment="Bottom">
            <Button Style="{StaticResource AuthButton}" Grid.Column="1" VerticalAlignment="Bottom" Margin="0,0,0,20"/>
        </StackPanel>
    </Grid>
</Page>
