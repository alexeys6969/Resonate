<UserControl x:Class="Resonate.Pages.Sales.Elements.NewProductItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Resonate.Pages.Sales.Elements"
             mc:Ignorable="d">
    <StackPanel>
        <TextBlock Text="Выберите товар 1" 
                   Style="{StaticResource MainTb}" 
                   Margin="0,15,0,5"/>

        <Grid HorizontalAlignment="Stretch" Margin="0,0,0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <!-- Кнопка удаления -->
                <ColumnDefinition Width="*"/>
                <!-- ComboBox -->
                <ColumnDefinition Width="Auto"/>
                <!-- X -->
                <ColumnDefinition Width="Auto"/>
                <!-- TextBox -->
                <ColumnDefinition Width="Auto"/>
                <!-- шт -->
            </Grid.ColumnDefinitions>

            <!-- Кнопка удаления -->
            <Button Grid.Column="0"
                    Height="30" 
                    Width="30" 
                    BorderThickness="0" 
                    VerticalAlignment="Center"
                    Background="Transparent"
                    Margin="0,0,10,0"
                    Click="DeleteProduct">
                <Image Source="/Images/deleteWhite.png" Width="18" Height="18"/>
            </Button>

            <!-- Комбобокс с товарами -->
            <ComboBox Grid.Column="1"
                      x:Name="Product" 
                      Style="{StaticResource RoundedWhiteComboBox}" 
                      VerticalAlignment="Center"
                      Height="35"
                      Margin="0,0,15,0"/>

            <!-- Разделитель "X" -->
            <TextBlock Grid.Column="2"
                       Text="X" 
                       Style="{StaticResource MainTb}" 
                       VerticalAlignment="Center" 
                       Margin="0,0,5,0"
                       FontSize="18"/>

            <!-- Поле для количества -->
            <TextBox Grid.Column="3"
                     Text="3" 
                     Style="{StaticResource TextboxWOBorder}" 
                     BorderThickness="0" 
                     Height="35"
                     VerticalAlignment="Center"
                     VerticalContentAlignment="Center"
                     HorizontalContentAlignment="Right"
                     Margin="0,0,0,0"/>
        </Grid>
    </StackPanel>
</UserControl>
