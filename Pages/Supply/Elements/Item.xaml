<UserControl x:Class="Resonate.Pages.Supply.Elements.Item"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Resonate.Pages.Supply.Elements"
             mc:Ignorable="d">
    <Border Background="#FFFFFF" CornerRadius="20">
        <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Первая строка: основная информация и кнопки -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <!-- Код и кассир -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Дата и сумма -->
                    <ColumnDefinition Width="*"/>
                    <!-- Кнопки -->
                </Grid.ColumnDefinitions>

                <!-- Код и кассир (с вашими отступами) -->
                <StackPanel Grid.Column="0" 
                            VerticalAlignment="Top" 
                            >
                    <TextBlock Text="Код: SUPP-S-001" 
                               Style="{StaticResource MainTb}" 
                               TextWrapping="Wrap" 
                               FontSize="18" 
                               VerticalAlignment="Center" 
                               HorizontalAlignment="Left" 
                               FontWeight="Medium" 
                               Foreground="#000000"
                               Margin="10,10,35,0"/>

                    <TextBlock Text="Дата продажи: 16 февраля 2026 14:30" 
                               Style="{StaticResource MainTb}" 
                               TextWrapping="Wrap" 
                               FontSize="18" 
                               VerticalAlignment="Center" 
                               HorizontalAlignment="Left" 
                               Foreground="#000000"
                               Margin="10,0,35,10"/>
                </StackPanel>

                <!-- Дата и сумма (с вашими отступами) -->
                <StackPanel Grid.Column="1" 
                            VerticalAlignment="Top"
                            >
                    <TextBlock Text="Сумма: 198500.00" 
                               Style="{StaticResource MainTb}" 
                               TextWrapping="Wrap" 
                               FontSize="18" 
                               VerticalAlignment="Top" 
                               HorizontalAlignment="Left" 
                               Foreground="#000000"
                               Margin="0,10,35,0"/>
                </StackPanel>

                <!-- Кнопки (с вашими отступами) -->
                <StackPanel Grid.Column="2" 
                            Orientation="Horizontal" 
                            HorizontalAlignment="Right" 
                            VerticalAlignment="Center"
                            Margin="0,10,15,10">

                    <Button Height="45" 
                            Width="45" 
                            BorderThickness="0" 
                            VerticalAlignment="Center"
                            >
                        <Button.Background>
                            <ImageBrush ImageSource="/Images/redact.png"/>
                        </Button.Background>
                    </Button>

                    <Button Height="45" 
                            Width="45" 
                            Margin="10,0,0,0" 
                            BorderThickness="0" 
                            VerticalAlignment="Center"
                            >
                        <Button.Background>
                            <ImageBrush ImageSource="/Images/delete.png"/>
                        </Button.Background>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Вторая строка: список товаров -->
            <StackPanel Grid.Row="1" Margin="10,0,10,10" >
                <TextBlock Text="Список товаров:" 
                           Style="{StaticResource MainTb}" 
                           TextWrapping="Wrap" 
                           FontSize="18" 
                           VerticalAlignment="Center" 
                           HorizontalAlignment="Left" 
                           FontWeight="Medium" 
                           Foreground="#000000"
                           Margin="0,0,0,5"/>

                <TextBlock Text="Гитара акустическая Yamaha FG800 х 5 =  14000,
Цифровое пианино Yamaha P-145 х 2 = 32000,
Струны для электрогитары Ernie Ball Regular Slinky х 20 = 600" MaxWidth="500"
                           Style="{StaticResource MainTb}" 
                           TextWrapping="Wrap" 
                           FontSize="18" 
                           HorizontalAlignment="Left" 
                           FontWeight="ExtraLight" 
                           Foreground="#000000" Margin="0"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
