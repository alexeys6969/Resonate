<Page x:Class="Resonate.Pages.Employees.Add"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Resonate.Pages.Employees"
      mc:Ignorable="d" d:DesignWidth="800"
      Title="Add" Background="#292929">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3.75*"/>
            <ColumnDefinition Width="92.5*"/>
            <ColumnDefinition Width="3.75*"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="1" VerticalAlignment="Top">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Система: Иванов И. И." x:Name="SystemUser" Style="{StaticResource MainTb}" TextDecorations="Underline" Margin="0,28,0,0"/>
                <TextBlock Style="{StaticResource LogoTb}" VerticalAlignment="Center" Grid.Column="1"/>
                <Button Style="{StaticResource MainButton}" Click="Exit" Content="Выйти" Grid.Column="2" Margin="78,20,0,0"/>
            </Grid>
        </StackPanel>
        <ScrollViewer Grid.Column="1" Margin="0,90,0,30" 
              VerticalScrollBarVisibility="Hidden">
            <StackPanel>
                <TextBlock Text="Введите ФИО" Style="{StaticResource MainTb}" Margin="0" HorizontalAlignment="Left"/>
                <TextBox x:Name="FIO" Style="{StaticResource MainTextbox}"/>
                <TextBlock Text="Выберите должность" Style="{StaticResource MainTb}" Margin="0,15,0,0" HorizontalAlignment="Left"/>
                <ComboBox x:Name="Position" Style="{StaticResource RoundedWhiteComboBox}" Height="30" Margin="0,10,0,0"/>
                <TextBlock Text="Введите логин" Style="{StaticResource MainTb}" Margin="0,15,0,0" HorizontalAlignment="Left"/>
                <TextBox x:Name="Login" Style="{StaticResource MainTextbox}"/>
                <TextBlock Text="Введите пароль" Style="{StaticResource MainTb}" Margin="0,15,0,0" HorizontalAlignment="Left"/>
                <PasswordBox x:Name="Pass" Style="{StaticResource MainPasswordbox}"/>

                <Button x:Name="AddEdit" Click="EditInfo" Style="{StaticResource MainButton}" Content="Добавить"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
