<Page x:Class="Resonate.Pages.Main"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Resonate.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Main" Background="#292929">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3.75*"/>
            <ColumnDefinition Width="92.5*"/>
            <ColumnDefinition Width="3.75*"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="1" VerticalAlignment="Top">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Система: Иванов И. И." x:Name="SystemUser" Style="{StaticResource MainTb}" TextDecorations="Underline" Margin="0,28,0,0"/>
                <TextBlock Style="{StaticResource LogoTb}" VerticalAlignment="Center" Grid.Column="1"/>
                <Button Style="{StaticResource MainButton}" Click="Exit" Content="Выйти" Grid.Column="2" Margin="78,20,0,0"/>
            </Grid>
        </StackPanel>
        <ScrollViewer Grid.Column="1" Margin="0,125,0,120" 
              VerticalScrollBarVisibility="Hidden">
            <StackPanel>
                <UniformGrid x:Name="MainWrapPanel" 
                    Columns="2" 
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Top"
                    Margin="0,0,-10,0">
                    <!--КНОПКА КАТЕГОРИЙ-->
                    <Button Style="{StaticResource AuthButton}" Margin="0,10,10,0" 
                    HorizontalAlignment="Stretch" 
                    VerticalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    MinHeight="100"
                    Background="#FFFFFF"
                    x:Name="CategoryBtn"
                    Click="CategoryClick">
                        <Border CornerRadius="15" 
                        Background="#FFFFFF"
                        HorizontalAlignment="Stretch" 
                        VerticalAlignment="Stretch">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Image Source="/Images/category.png" 
                                Width="60" Height="60"
                                Stretch="Uniform"
                                HorizontalAlignment="Center"
                                Margin="0,10,0,0"/>
                                <TextBlock Style="{StaticResource MainTb}" 
                                Text="Категории" 
                                Foreground="#000000" 
                                Margin="0,0,0,5"  
                                FontSize="20"
                                FontWeight="Light"
                                HorizontalAlignment="Center"
                                TextWrapping="Wrap"
                                TextAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Button>

                    <!--КНОПКА СОТРУДНИКОВ-->
                    <Button Style="{StaticResource AuthButton}" Margin="0,10,10,0" 
                    HorizontalAlignment="Stretch" 
                    VerticalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    MinHeight="100"
                    Background="#FFFFFF"
                    x:Name="EmployeeBtn"
                    Click="EmployeeClick">
                        <Border CornerRadius="15" 
                        Background="#FFFFFF"
                        HorizontalAlignment="Stretch" 
                        VerticalAlignment="Stretch">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Image Source="/Images/employeesIcon.png" 
                                Width="60" Height="60"
                                Stretch="Uniform"
                                HorizontalAlignment="Center"
                                Margin="0,10,0,0"/>
                                <TextBlock Style="{StaticResource MainTb}" 
                                Text="Сотрудники" 
                                Foreground="#000000" 
                                Margin="0,0,0,5"  
                                FontSize="20"
                                FontWeight="Light"
                                HorizontalAlignment="Center"
                                TextWrapping="Wrap"
                                TextAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Button>

                    <!--КНОПКА ТОВАРОВ-->
                    <Button Style="{StaticResource AuthButton}" Margin="0,10,10,0" 
                    HorizontalAlignment="Stretch" 
                    VerticalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    MinHeight="100"
                    Background="#FFFFFF"
                    x:Name="ProductBtn"
                    Click="ProductClick">
                        <Border CornerRadius="15" 
                        Background="#FFFFFF"
                        HorizontalAlignment="Stretch" 
                        VerticalAlignment="Stretch">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Image Source="/Images/product.png" 
                                Width="60" Height="60"
                                Stretch="Uniform"
                                HorizontalAlignment="Center"
                                Margin="0,10,0,0"/>
                                <TextBlock Style="{StaticResource MainTb}" 
                                Text="Товары" 
                                Foreground="#000000" 
                                Margin="0,0,0,5"  
                                FontSize="20"
                                FontWeight="Light"
                                HorizontalAlignment="Center"
                                TextWrapping="Wrap"
                                TextAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Button>

                    <!--КНОПКА ПРОДАЖ-->
                    <Button Style="{StaticResource AuthButton}" Margin="0,10,10,0" 
                    HorizontalAlignment="Stretch" 
                    VerticalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    MinHeight="100"
                    Background="#FFFFFF"
                    x:Name="SaleBtn"
                    Click="SaleClick">
                        <Border CornerRadius="15" 
                        Background="#FFFFFF"
                        HorizontalAlignment="Stretch" 
                        VerticalAlignment="Stretch">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Image Source="/Images/sales.png" 
                                Width="60" Height="60"
                                Stretch="Uniform"
                                HorizontalAlignment="Center"
                                Margin="0,10,0,0"/>
                                <TextBlock Style="{StaticResource MainTb}" 
                                Text="Продажи" 
                                Foreground="#000000" 
                                Margin="0,0,0,5"  
                                FontSize="20"
                                FontWeight="Light"
                                HorizontalAlignment="Center"
                                TextWrapping="Wrap"
                                TextAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Button>

                    <!--КНОПКА ПОСТАВЩИКОВ-->
                    <Button Style="{StaticResource AuthButton}" Margin="0,10,10,0" 
                    HorizontalAlignment="Stretch" 
                    VerticalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    MinHeight="100"
                    Background="#FFFFFF"
                    x:Name="SupplierBtn"
                    Click="SupplierClick">
                        <Border CornerRadius="15" 
                        Background="#FFFFFF"
                        HorizontalAlignment="Stretch" 
                        VerticalAlignment="Stretch">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Image Source="/Images/suppliers.png" 
                                Width="60" Height="60"
                                Stretch="Uniform"
                                HorizontalAlignment="Center"
                                Margin="0,10,0,0"/>
                                <TextBlock Style="{StaticResource MainTb}" 
                                Text="Поставщики" 
                                Foreground="#000000" 
                                Margin="0,0,0,5"  
                                FontSize="20"
                                FontWeight="Light"
                                HorizontalAlignment="Center"
                                TextWrapping="Wrap"
                                TextAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Button>

                    <!--КНОПКА ПОСТАВОК-->
                    <Button Style="{StaticResource AuthButton}" Margin="0,10,10,0" 
                    HorizontalAlignment="Stretch" 
                    VerticalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    MinHeight="100"
                    Background="#FFFFFF"
                    x:Name="SupplyBtn"
                    Click="SupplyClick">
                        <Border CornerRadius="15" 
                        Background="#FFFFFF"
                        HorizontalAlignment="Stretch" 
                        VerticalAlignment="Stretch">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Image Source="/Images/supply.png" 
                                Width="60" Height="60"
                                Stretch="Uniform"
                                HorizontalAlignment="Center"
                                Margin="0,10,0,0"/>
                                <TextBlock Style="{StaticResource MainTb}" 
                                Text="Поставки" 
                                Foreground="#000000" 
                                Margin="0,0,0,5"  
                                FontSize="20"
                                FontWeight="Light"
                                HorizontalAlignment="Center"
                                TextWrapping="Wrap"
                                TextAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Button>
                </UniformGrid>

            </StackPanel>
        </ScrollViewer>
        <Button Click="ReportForm" Style="{StaticResource MainButton}" Content="Сформировать отчет" Grid.Column="1" VerticalAlignment="Bottom" Margin="0,40,0,40"/>
    </Grid>
</Page>
