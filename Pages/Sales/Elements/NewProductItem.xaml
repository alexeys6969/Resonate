<UserControl x:Class="Resonate.Pages.Sales.Elements.NewProductItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Resonate.Pages.Sales.Elements"
             mc:Ignorable="d"
             Margin="0,12,0,0">

    <UserControl.Resources>
        <!-- Анимация появления -->
        <Storyboard x:Key="SlideIn">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.2"/>
            <ThicknessAnimation Storyboard.TargetProperty="Margin" From="0,-10,0,0" To="0,12,0,0" Duration="0:0:0.3">
                <ThicknessAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </ThicknessAnimation.EasingFunction>
            </ThicknessAnimation>
        </Storyboard>

        <!-- Анимация удаления -->
        <Storyboard x:Key="SlideOut">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0" Duration="0:0:0.2"/>
            <ThicknessAnimation Storyboard.TargetProperty="Margin" To="0,-10,0,0" Duration="0:0:0.2"/>
        </Storyboard>
    </UserControl.Resources>

    <Border x:Name="RootBorder"
            Background="#252525"
            BorderBrush="#3a3a3a"
            BorderThickness="1"
            Padding="16,12"
            CornerRadius="12">

        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Effect" Value="{x:Null}"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="BorderBrush" Value="#8EED45"/>
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect Color="#8EED45" BlurRadius="15" ShadowDepth="0" Opacity="0.25"/>
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <!-- 🔴 Кнопка удаления -->
                <ColumnDefinition Width="*"/>
                <!-- 📦 ComboBox товара -->
                <ColumnDefinition Width="Auto"/>
                <!-- ✕ Разделитель -->
                <ColumnDefinition Width="Auto"/>
                <!-- 🔢 Количество -->
                <ColumnDefinition Width="Auto"/>
                <!-- 📊 Сумма строки (опционально) -->
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 🔴 Кнопка удаления -->
            <Button x:Name="DeleteButton"
                    Grid.Column="0"
                    Width="32" Height="32"
                    Margin="0,0,12,0"
                    Click="DeleteProduct"
                    Style="{StaticResource IconButtonSmall}"
                    ToolTip="Удалить товар">
                <Viewbox Width="16" Height="16">
                    <Canvas Width="24" Height="24">
                        <Path Fill="#ff5252" 
                              Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z"/>
                    </Canvas>
                </Viewbox>
            </Button>

            <!-- 📦 ComboBox с товарами -->
            <Border Grid.Column="1"
                    Background="#2e2e2e"
                    BorderBrush="#444444"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12,8"
                    Margin="0,0,12,0">
                <ComboBox x:Name="Product"
                          Style="{StaticResource DarkComboBoxCompact}"
                          Tag="Выберите товар..."
                          SelectionChanged="Product_SelectionChanged"/>
            </Border>

            <!-- ✕ Разделитель -->
            <TextBlock Grid.Column="2"
                       Text="×"
                       FontFamily="\Fonts\Inter-VariableFont_opsz,wght.ttf"
                       FontSize="16"
                       FontWeight="Medium"
                       Foreground="#666666"
                       VerticalAlignment="Center"
                       Margin="0,0,12,0"/>

            <!-- 🔢 Поле количества -->
            <Border Grid.Column="3"
                    Background="#2e2e2e"
                    BorderBrush="#444444"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10,8"
                    Margin="0,0,12,0"
                    Width="70">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="Quantity"
                             Style="{StaticResource TransparentTextBoxCompact}"
                             Text="1"
                             TextAlignment="Right"
                             PreviewTextInput="Quantity_PreviewTextInput"
                             TextChanged="Quantity_TextChanged"
                             VerticalContentAlignment="Center"/>

                    <!-- Кнопки +/- для быстрого изменения -->
                    <StackPanel Grid.Column="1" Orientation="Vertical" Margin="6,0,0,0">
                        <RepeatButton Width="16" Height="12" 
                                      Click="IncrementQuantity"
                                      Style="{StaticResource SpinButton}"
                                      Content="▲"/>
                        <RepeatButton Width="16" Height="12" 
                                      Click="DecrementQuantity"
                                      Style="{StaticResource SpinButton}"
                                      Content="▼"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 📊 Сумма строки (живой подсчёт) -->
            <TextBlock x:Name="LineTotal"
                       Grid.Column="4"
                       Text="0.00 ₽"
                       FontFamily="\Fonts\Inter-VariableFont_opsz,wght.ttf"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="#8EED45"
                       VerticalAlignment="Center"
                       MinWidth="80"
                       TextAlignment="Right"/>
        </Grid>
    </Border>
</UserControl>