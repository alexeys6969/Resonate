<UserControl x:Class="Resonate.Pages.Suppliers.Elements.Item"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Resonate.Pages.Suppliers.Elements"
             mc:Ignorable="d"
             Margin="0,15,0,0"
             MinHeight="120">

    <Border x:Name="RootBorder"
            Background="#2a2a2a" 
            BorderBrush="#3a3a3a"
            BorderThickness="1"
            Padding="25,20"
            Cursor="Hand"
            CornerRadius="20">

        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Effect" Value="{x:Null}"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="BorderBrush" Value="#8EED45"/>
                        <Setter Property="Background" Value="#2e2e2e"/>
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect Color="#8EED45" BlurRadius="20" ShadowDepth="0" Opacity="0.3"/>
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Левая часть: Название и контакты -->
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock x:Name="SupplierName" 
                           FontFamily="\Fonts\Inter-VariableFont_opsz,wght.ttf"
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="#ffffff"
                           TextWrapping="Wrap"
                           Margin="0,0,0,8"/>

                <TextBlock x:Name="ContactInfo" 
                           FontFamily="\Fonts\Inter-VariableFont_opsz,wght.ttf"
                           FontSize="13" FontWeight="Light"
                           Foreground="#999999"
                           TextWrapping="Wrap"
                           MaxWidth="500"/>
            </StackPanel>

            <!-- Правая часть: Кнопки -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                <Button x:Name="EditButton" Width="42" Height="42" Margin="0,0,10,0"
                        Style="{StaticResource ActionButton}" Click="Edit">
                    <Viewbox Width="20" Height="20">
                        <Canvas Width="24" Height="24">
                            <Path Fill="#8EED45" Data="M3,17.25V21H6.75L17.81,9.94L14.06,6.19L3,17.25M20.71,7.04C21.1,6.65 21.1,6 20.71,5.63L18.37,3.29C18,2.9 17.35,2.9 16.96,3.29L15.13,5.12L18.88,8.87L20.71,7.04Z"/>
                        </Canvas>
                    </Viewbox>
                </Button>
                <Button x:Name="DeleteButton" Width="42" Height="42"
                        Style="{StaticResource ActionButton}" Click="Delete">
                    <Viewbox Width="20" Height="20">
                        <Canvas Width="24" Height="24">
                            <Path Fill="#ff5252" Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z"/>
                        </Canvas>
                    </Viewbox>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>