<Window x:Class="Resonate.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Resonate — Музыкальный магазин"
        WindowState="Maximized"
        MinHeight="800" 
        MinWidth="1000"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="#1E1E1E">

    <Grid>
        <!-- Кастомная верхняя панель -->
        <Border Background="#252525" 
                Height="50" 
                VerticalAlignment="Top"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" 
                            VerticalAlignment="Center" 
                            Margin="20,0,0,0">
                    <TextBlock Text="Resonate" 
                               Foreground="#FFFFFF"
                               FontSize="18"
                               FontWeight="SemiBold"
                               FontFamily="C:\Users\alexs\OneDrive\Рабочий стол\резерв флешки\ОАиП\Resonate\Fonts\Inter-VariableFont_opsz,wght.ttf"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <!-- Кнопки управления окном (Title Bar) -->
                <StackPanel Grid.Column="2" 
            Orientation="Horizontal" 
            VerticalAlignment="Stretch"
            Margin="0,0,5,0">

                    <!-- Свернуть -->
                    <Button Style="{StaticResource TitleBarButton}" 
            Width="46" 
            Height="50"
            Click="Minimize_Click">
                        <TextBlock Text="−" 
                   FontSize="20" 
                   FontWeight="Light"
                   VerticalAlignment="Center" 
                   HorizontalAlignment="Center"/>
                    </Button>

                    <!-- Развернуть / Восстановить -->
                    <Button x:Name="btnMaximize" 
            Style="{StaticResource TitleBarButton}" 
            Width="46" 
            Height="50"
            Click="Maximize_Click">
                        <TextBlock x:Name="txtMaximizeIcon" 
                   Text="□" 
                   FontSize="18" 
                   FontWeight="Light"
                   VerticalAlignment="Center" 
                   HorizontalAlignment="Center"/>
                    </Button>

                    <!-- Закрыть -->
                    <Button Style="{StaticResource TitleBarButtonClose}" 
            Width="46" 
            Height="50"
            Click="Close_Click">
                        <TextBlock Text="✕" 
                   FontSize="19" 
                   FontWeight="Light"
                   VerticalAlignment="Center" 
                   HorizontalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Основной контент -->
        <Grid Margin="0,50,0,0">
            <Frame x:Name="frame" NavigationUIVisibility="Hidden"/>
        </Grid>
    </Grid>
</Window>